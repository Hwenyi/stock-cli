{
  "name": "stock-cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CLI for fetching HK and US stock quotes with stock-sdk.",
  "bin": {
    "stock-cli": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "check": "tsc --noEmit",
    "build": "bun run build:bun",
    "build:bun": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/bin/stock-cli",
    "build:bun:macos-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/bin/stock-cli",
    "build:bun:windows-x64": "bun build src/cli.ts --compile --target=bun-windows-x64-baseline --outfile dist/bin/stock-cli.exe",
    "build:tsdown": "bunx tsdown --config tsdown.config.ts",
    "build:all": "bun run build:bun && bun run build:bun:windows-x64",
    "build:release": "bun run scripts/build-release.ts",
    "verify:offline": "bun run scripts/verify-binary.ts",
    "test:packaging": "bun run scripts/compare-builds.ts",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "dependencies": {
    "stock-sdk": "^1.7.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.5.2",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.3.10"
}
